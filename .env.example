# ─────────────────────────────────────────────────────────────
#  Environment variables (copy to .env.local for local overrides)
# ─────────────────────────────────────────────────────────────

# Canonical production URL — set this in Vercel ONCE you connect a custom
# domain, e.g. https://www.your-agency.com  (no trailing slash).
# If unset, the site auto-detects your *.vercel.app production URL, so you
# usually don't need this until you have a real domain.
NEXT_PUBLIC_SITE_URL=https://watchthebabyllc.com

# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Adds the verification <meta> tag site-wide.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────
#  Contact form email (PDF + Excel attachments)
# ─────────────────────────────────────────────────────────────
# Business mail runs entirely on Zoho Mail (Mail Lite plan, US data center):
#   • Receives — the MX records for watchthebabyllc.com point at Zoho, which
#                hosts the info@watchthebabyllc.com mailbox. It is read in
#                Outlook 2021 over IMAP (imap.zoho.com:993, SSL).
#   • Sends    — the same account relays the site's outgoing mail, so enquiries
#                are sent AS info@watchthebabyllc.com.
#
# SMTP_USER is the full mailbox address. SMTP_PASSWORD is an application-
# specific password from accounts.zoho.com → Security → Application Specific
# Passwords — NOT the mailbox's own password. Generate a separate one from the
# Outlook password so either can be revoked without breaking the other.
# When both are set, enquiries arrive with PDF + Excel attachments.
# When unset, the form falls back to FormSubmit (plain email, no attachments).
SMTP_USER=
SMTP_PASSWORD=

# Optional — only if you move off Zoho. Defaults: smtp.zoho.com : 587.
SMTP_HOST=
SMTP_PORT=

# Legacy fallback: the old personal Gmail account + App Password. Still honoured
# if SMTP_USER/SMTP_PASSWORD are absent, but it sends as the Gmail address
# rather than as info@watchthebabyllc.com. Safe to delete once Zoho is live.
GMAIL_USER=
GMAIL_APP_PASSWORD=
