# ─────────────────────────────────────────────────────────────
#  Environment variables (copy to .env.local for local overrides)
# ─────────────────────────────────────────────────────────────

# Canonical production URL — set this in Vercel ONCE you connect a custom
# domain, e.g. https://www.your-agency.com  (no trailing slash).
# If unset, the site auto-detects your *.vercel.app production URL, so you
# usually don't need this until you have a real domain.
NEXT_PUBLIC_SITE_URL=https://www.watchthebabyllc.com

# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Adds the verification <meta> tag site-wide.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────
#  Contact form email (PDF + Excel attachments)
# ─────────────────────────────────────────────────────────────
# Business mail runs on two free services:
#   • ImprovMX  — MX records for watchthebabyllc.com; forwards anything sent to
#                 info@watchthebabyllc.com on to the personal Gmail inbox.
#   • Brevo     — SMTP relay that lets the site SEND as info@watchthebabyllc.com.
#
# Credentials below come from Brevo → Settings → SMTP & API → SMTP tab.
# SMTP_USER looks like 9xxxxx@smtp-brevo.com (it is NOT the info@ address);
# SMTP_PASSWORD is the generated SMTP key.
# When both are set, enquiries arrive with PDF + Excel attachments.
# When unset, the form falls back to FormSubmit (plain email, no attachments).
SMTP_USER=
SMTP_PASSWORD=

# Optional — only if you move off Brevo. Defaults: smtp-relay.brevo.com : 587.
SMTP_HOST=
SMTP_PORT=

# Legacy fallback: the old personal Gmail account + App Password. Still honoured
# if SMTP_USER/SMTP_PASSWORD are absent, but it sends as the Gmail address
# rather than as info@watchthebabyllc.com. Safe to delete once Brevo is live.
GMAIL_USER=
GMAIL_APP_PASSWORD=
