# ─────────────────────────────────────────────────────────────
#  Environment variables (copy to .env.local for local overrides)
# ─────────────────────────────────────────────────────────────

# Canonical production URL — set this in Vercel ONCE you connect a custom
# domain, e.g. https://www.your-agency.com  (no trailing slash).
# If unset, the site auto-detects your *.vercel.app production URL, so you
# usually don't need this until you have a real domain.
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Adds the verification <meta> tag site-wide.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
